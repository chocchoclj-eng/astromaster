{
  "version": "v1.0",
  "__doc": {
    "purpose": "星盘评分引擎配置（Trait22 + Node脚本NSV8 + Domain），用于读取 keyConfig.coreFull.planets / raw.bodies.lon 计算分数与证据链",
    "notes": [
      "Rel: 行星->Trait相关度(0~1) 决定谁负责该能力",
      "Alpha: Trait对星座能量向量(SEV)的线性系数，SignAdj clamp到[-0.15,+0.15]",
      "HouseAct: 宫位对Trait的激活(0~0.40)，用于(1+HouseAct)乘到行星贡献",
      "Aspects: 从lon计算相位，w(type,orb)=base*(1-orb/allowedOrb)，再乘PairEffect并带sign(type)",
      "NSV: 交点脚本8维，用交点相位强度NAS + 宫位触发 + Trait稳定系统生成"
    ]
  },

  "bodies": {
    "__doc": "你代码里的代号对齐（chartToKeyConfig 推入 planets[] 的 body 字段）",
    "list": [
      "Sun",
      "Moon",
      "Mercury",
      "Venus",
      "Mars",
      "Jupiter",
      "Saturn",
      "Uranus",
      "Neptune",
      "Pluto",
      "NorthNode",
      "SouthNode",
      "ASC",
      "MC"
    ],
    "node": {
      "northKey": "NorthNode",
      "southKey": "SouthNode",
      "swephTrueNodeKeys": ["TrueNode_North", "TrueNode_South"]
    }
  },

  "weights": {
    "planetBaseWeight_PW": {
      "Sun": 1.0,
      "Moon": 0.95,
      "Mercury": 0.9,
      "Venus": 0.85,
      "Mars": 0.9,
      "Jupiter": 0.8,
      "Saturn": 0.85,
      "Uranus": 0.7,
      "Neptune": 0.65,
      "Pluto": 0.75,

      "__doc_nodes": "交点主要用于脚本(NSV)，Trait层可设为0或极低；如果你希望Trait也被交点影响，可在Rel矩阵里给小值",
      "NorthNode": 1.1,
      "SouthNode": 1.2,

      "__doc_angles": "轴点（ASC/MC）建议只用于Domain/显性修正；Trait层如要用可给0.6左右",
      "ASC": 0.6,
      "MC": 0.6
    },

    "repetitionFactor": {
      "__doc": "同一宫位内(含节点/角度可选) >=2 个点位时，对该宫位内所有点位贡献乘该系数",
      "enabled": true,
      "minCountInHouse": 2,
      "factor": 1.25,
      "includeBodies": [
        "Sun",
        "Moon",
        "Mercury",
        "Venus",
        "Mars",
        "Jupiter",
        "Saturn",
        "Uranus",
        "Neptune",
        "Pluto",
        "NorthNode",
        "SouthNode"
      ]
    }
  },

