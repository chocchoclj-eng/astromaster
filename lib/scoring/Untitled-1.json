  "B_aspects": {
    "__doc": "相位计算与权重，输入lon直接算出aspect列表，再进Trait/NSV/证据链",
    "enabled": true,
    "targets": [0, 60, 90, 120, 180],
    "allowedOrb": { "conj": 8, "sextile": 4, "square": 6, "trine": 6, "opposition": 8 },
    "base": { "conj": 0.35, "sextile": 0.18, "square": 0.35, "trine": 0.25, "opposition": 0.40 },
    "signOfAspect": { "trine": 1, "sextile": 1, "square": -1, "opposition": -1, "conj": 0 },
    "weightFormula": "w=base*(1-orb/allowedOrb)",
    "includeBodies": ["Sun","Moon","Mercury","Venus","Mars","Jupiter","Saturn","Uranus","Neptune","Pluto","NorthNode","SouthNode"]
  },

  "nodeScript_NSV": {
    "__doc": "交点脚本NSV8维配置",
    "nodePairWeight": {
      "Saturn": 1.0,
      "Pluto": 1.0,
      "Moon": 0.7,
      "Venus": 0.6,
      "Mars": 0.6,
      "Mercury": 0.5,
      "Jupiter": 0.4,
      "Uranus": 0.3,
      "Neptune": 0.3,
      "Sun": 0.3
    },
    "triggerIntensityByHouse": {
      "1": 0.3, "2": 0.8, "3": 0.4, "4": 0.6, "5": 0.4, "6": 0.3,
      "7": 0.6, "8": 0.9, "9": 0.4, "10": 0.6, "11": 0.4, "12": 0.8
    },
    "formulas": {
      "NAS": "sum(w(type,orb)*nodePairWeight(planet)) over aspects(node,planet)",
      "FallbackStrength": "clamp(40 + 35*NAS(South) + 15*TriggerIntensity(SouthHouse),0,100)",
      "UpgradePull": "clamp(40 + 30*NAS(North) + 20*TriggerIntensity(NorthHouse),0,100)",
      "GrowthFriction": "clamp(35 + 40*HardAspects(North) + 15*SaturnLink(North),0,100)",
      "RepeatLoopIndex": "100*sigmoid(0.7*Fallback + 0.5*Friction - 0.4*IntegrationAbility)",
      "IntegrationAbility": "min(SelfTrust,BoundaryStrength,DisciplineRoutine)"
    }
  },

